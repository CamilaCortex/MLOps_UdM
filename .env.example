# =============================================================================
# MLOps Course - Variables de Entorno
# =============================================================================
# Copia este archivo como .env y reemplaza los valores con los tuyos:
#   cp .env.example .env
#
# NUNCA commitees el archivo .env (ya esta en .gitignore)
# =============================================================================

# --- MLflow ---
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
# Para servidor remoto:
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_S3_ENDPOINT_URL=https://s3.amazonaws.com
# AWS_ACCESS_KEY_ID=tu-access-key
# AWS_SECRET_ACCESS_KEY=tu-secret-key

# --- Prefect ---
PREFECT_API_URL=http://127.0.0.1:4200/api
# PREFECT_API_KEY=tu-prefect-api-key

# --- Datos ---
DATA_DIR=./data
MODELS_DIR=./models

# --- Python ---
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1
